{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["vue", "typescript", "oxc", "unicorn"],
  "rules": {
    "no-console": "off",
    "no-unused-vars": "warn"
  },
  "settings": {
    "vue": {
      "block-order": ["template", "script", "style"]
    }
  },
  "ignorePatterns": [
    "public/mockServiceWorker.js",
    "**/fixtures",
    "**/assets/images",
    "**/node_modules",
    "**/dist",
    "**/envs",
    "**/*.md",
    "**/*.{png,jpg,jpeg,gif,svg,webp}",
    "**/*.json",
    "**/ofetch/**/*.ts",
    "**/mocks/**/*.ts"
  ]
}
